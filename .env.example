# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_GUILD_ID=your_test_guild_id_here   # optional: instant command registration during dev

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Local dev: path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/service-account.json
# Railway/production: paste the entire JSON as a single-line string instead:
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# ── Teams ─────────────────────────────────────────────────────────────────────
# Add one block per raid team. The sheet ID is the long string in the Sheets URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
#
# CONSOLE_CHANNEL  — the #raid-console channel where panels are posted (officers only)
# BRIEF_CHANNEL    — the #brief channel for pre-raid briefs (officers read)
# OFFICER_ROLE     — Discord role ID for officers (fallback; Config tab takes precedence)
# MEMBER_ROLE      — Discord role ID for team members

TEAM_MYTHIC_SHEET_ID=your_sheet_id_here
TEAM_MYTHIC_CONSOLE_CHANNEL=123456789012345678
TEAM_MYTHIC_BRIEF_CHANNEL=123456789012345679
TEAM_MYTHIC_OFFICER_ROLE=123456789012345680
TEAM_MYTHIC_MEMBER_ROLE=123456789012345681

# TEAM_HEROIC_SHEET_ID=another_sheet_id_here
# TEAM_HEROIC_CONSOLE_CHANNEL=123456789012345682
# TEAM_HEROIC_BRIEF_CHANNEL=123456789012345683
# TEAM_HEROIC_OFFICER_ROLE=123456789012345684
# TEAM_HEROIC_MEMBER_ROLE=123456789012345685
