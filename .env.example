# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_CLIENT_SECRET=your_application_client_secret_here

# Used only by deploy-commands.js for instant guild-scoped command registration during dev.
# Not required at runtime — all runtime config comes from the Config sheet.
# DISCORD_GUILD_ID=your_test_guild_id_here

# ── Google Sheets ─────────────────────────────────────────────────────────────
# Local dev: path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/service-account.json
# Railway/production: paste the entire JSON as a single-line string instead:
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"..."}

# ── Teams ─────────────────────────────────────────────────────────────────────
# One TEAM_<NAME>_SHEET_ID per raid team. The sheet ID is the long string in the
# Sheets URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
#
# All other team config (channel IDs, role IDs, guild ID) lives in each team's
# Google Sheet Config tab — no extra env vars needed.
# See CLAUDE.md for the full list of Config sheet keys.

TEAM_MYTHIC_SHEET_ID=your_sheet_id_here

# TEAM_HEROIC_SHEET_ID=another_sheet_id_here

# ── Web app ───────────────────────────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-random-string-in-production
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
# CLIENT_URL=http://localhost:3000   # dev default; set to your domain in production
# WEB_PORT=3001                      # default 3001
