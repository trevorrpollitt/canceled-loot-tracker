{
  "name": "canceled-loot-tracker",
  "version": "0.1.0",
  "description": "Canceled guild loot tracker Discord bot",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "deploy-commands": "node src/deploy-commands.js",
    "seed:list":       "node --env-file=.env scripts/seed-item-db.js list",
    "seed:raid":       "node --env-file=.env scripts/seed-item-db.js raid",
    "seed:dungeon":    "node --env-file=.env scripts/seed-item-db.js dungeon",
    "seed:sync":       "node --env-file=.env scripts/seed-item-db.js sync",
    "seed:guide":      "node --env-file=.env scripts/seed-item-db.js guide",
    "seed:wowhead":    "node --env-file=.env scripts/seed-item-db.js wowhead",
    "seed:s1mplus":    "node --env-file=.env scripts/seed-item-db.js s1mplus https://www.wowhead.com/guide/midnight/season-1-mythic-rewards-loot-drops-mounts-achievements",
    "seed:bis":        "node --env-file=.env scripts/seed-default-bis.js fetch",
    "seed:bis-all":    "node --env-file=.env scripts/seed-default-bis.js fetch-all",
    "seed:bis-list":   "node --env-file=.env scripts/seed-default-bis.js list",
    "backfill:weapons": "node --env-file=.env scripts/backfill-weapon-types.js"
  },
  "dependencies": {
    "discord.js": "^14.16.3",
    "googleapis": "^144.0.0",
    "dotenv": "^16.4.5"
  }
}
